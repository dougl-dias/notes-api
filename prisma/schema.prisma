generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note Note[]
}

model Note {
  id       Int       @id @default(autoincrement())
  title    String
  content  String?
  category String
  color    NoteColor @default(gray)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

enum NoteColor {
  yellow
  green
  cyan
  pink
  purple
  gray
}
